# --- Platform keypair (fee payer + tree authority + collection authority + delegate) ---
# Base58-encoded secret key. Generate with `solana-keygen new`, then convert to base58.
PLATFORM_SECRET_KEY=

# --- DAS-capable Solana RPC (cNFTs REQUIRE this) — Helius / Triton devnet endpoint ---
SOLANA_RPC_URL=

# --- 32-byte base64 key for encrypting managed-wallet secrets (openssl rand -base64 32) ---
WALLET_ENCRYPTION_KEY=

# --- Shared secret the mint-coa edge function presents in the `x-signer-secret` header ---
SIGNER_SHARED_SECRET=

# --- Supabase (service role) — signer writes managed_wallets / profiles directly ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Produced by `npm run setup` (one-time, devnet) — paste the printed values here ---
CORE_COLLECTION_ADDRESS=
BUBBLEGUM_TREE_ADDRESS=

# --- HTTP port ---
PORT=8080

# --- Used only by scripts/setup.ts for the collection metadata pointer ---
# Defaults to the app-hosted public/collection.json if left unset.
COLLECTION_METADATA_URI=https://authenti-seek.lovable.app/collection.json
